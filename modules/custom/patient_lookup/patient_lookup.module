/**
 * AJAX callback function to fetch patient details and return the rendered card.
 */
function patient_lookup_ajax_callback(array &$form, FormStateInterface $form_state) {
  // Get the referenced Node ID from the field
  $pid_value = $form_state->getValue(['field_pid', 0, 'target_id']);

  if (!empty($pid_value)) {
    // Load the patient node
    $node = Node::load($pid_value);

    // Verify it exists and is the correct content type
    if ($node instanceof \Drupal\node\NodeInterface) {
      
      // Pass the actual database values into our Twig template
      $form['patient_info_wrapper']['content'] = [
        '#theme' => 'patient_summary_card',
        '#name' => $node->get('field_first_name')->value . ' ' . $node->get('field_last_name')->value,
        '#gender' => $node->get('field_gender')->value, 
        '#dob' => $node->get('field_date_of_birth')->value,
        '#phone' => $node->get('field_phone_number')->value,
      ];
    }
  } else {
    // If the field is cleared out, empty the wrapper
    $form['patient_info_wrapper']['content'] = ['#markup' => ''];
  }

  // Return the rebuilt wrapper container
  return $form['patient_info_wrapper'];
}

