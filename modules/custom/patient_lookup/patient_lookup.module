<?php

use Drupal\Core\Form\FormStateInterface;
use Drupal\node\Entity\Node;

/**
 * Implements hook_theme().
 * Registers our custom Twig template for the patient card.
 */
function patient_lookup_theme($existing, $type, $theme, $path) {
  return [
    // Your existing AJAX card theme...
    'patient_summary_card' => [
      'variables' => [
        'name' => NULL,
        'gender' => NULL,
        'dob' => NULL,
        'blood' => NULL,
        'phone' => NULL,
      ],
    ],
    // The NEW block theme
    'patient_demographics_block' => [
      'variables' => [
        'content' => [],
      ],
    ],
  ];
}

/**
 * Implements hook_form_FORM_ID_alter() for node_out_patient_department_form.
 */
function patient_lookup_form_node_out_patient_department_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  
  // 1. Create an empty container wrapper right below the PID field.
  // This is where our AJAX callback will inject the HTML card.
  $form['patient_info_wrapper'] = [
    '#type' => 'container',
    '#attributes' => ['id' => 'patient-info-ajax-wrapper', 'class' => ['mb-4']],
    // Place it immediately after the field_pid widget
    '#weight' => isset($form['field_pid']['#weight']) ? $form['field_pid']['#weight'] + 0.1 : 1,
  ];

  // 2. Attach AJAX to the Entity Reference Autocomplete widget
  if (isset($form['field_pid']['widget'][0]['target_id'])) {
    $form['field_pid']['widget'][0]['target_id']['#ajax'] = [
      'callback' => 'patient_lookup_ajax_callback',
      'event' => 'autocompleteclose', // Triggers when the user selects a patient from the dropdown
      'wrapper' => 'patient-info-ajax-wrapper',
      'progress' => [
        'type' => 'throbber',
        'message' => t('Loading patient data...'),
      ],
    ];
  }
}

