      ],

      'description__format' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => FALSE,
      ],

      'status' => [
        'type' => 'int',
        'size' => 'tiny',
        'not null' => TRUE,
        'default' => 1,
      ],

      'uid' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 0,
      ],

      'created' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ],

      'changed' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
