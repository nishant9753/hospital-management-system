      // Drug rows moved to billing_items table.

      'subtotal' => [
        'type' => 'numeric',
        'precision' => 10,
        'scale' => 2,
        'not null' => TRUE,
        'default' => 0,
      ],

      'discount' => [
        'type' => 'numeric',
        'precision' => 10,
        'scale' => 2,
