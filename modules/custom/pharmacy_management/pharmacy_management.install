      'drug_id' => ['drug_id'],
    ],
  ];

  return $schema;
}

/**
 * Implements hook_uninstall().
 */
function pharmacy_management_uninstall(): void {

  $schema = \Drupal::database()->schema();

  if ($schema->tableExists('billing_items')) {
    $schema->dropTable('billing_items');
  }

  if ($schema->tableExists('billing')) {
    $schema->dropTable('billing');
  }

  if ($schema->tableExists('drug')) {
    $schema->dropTable('drug');
  }
}