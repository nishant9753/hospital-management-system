        'not null' => TRUE,
        'default' => 0,
      ],

      'tax_amount' => [
        'type' => 'numeric',
        'precision' => 10,
        'scale' => 2,
        'not null' => TRUE,
        'default' => 0,
      ],

      'total_amount' => [
        'type' => 'numeric',
        'precision' => 10,
        'scale' => 2,
        'not null' => TRUE,
        'default' => 0,
      ],

      'payment_method' => [
        'type' => 'varchar',
        'length' => 32,
        'not null' => FALSE,
      ],

      'payment_status' => [
        'type' => 'varchar',
        'length' => 32,
        'not null' => TRUE,
        'default' => 'paid',
      ],

      'billing_date' => [
        'type' => 'varchar',
        'length' => 20,
        'not null' => FALSE,
      ],

      'notes__value' => [
        'type' => 'text',
        'size' => 'big',
        'not null' => FALSE,
      ],

      'notes__format' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => FALSE,
      ],

      'status' => [
        'type' => 'int',
        'size' => 'tiny',
        'not null' => TRUE,
        'default' => 1,
      ],

      'created' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ],

      'changed' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ],
    ],

    'primary key' => ['id'],

    'unique keys' => [
      'uuid' => ['uuid'],
      'invoice_number' => ['invoice_number'],
    ],

    'indexes' => [
      'status' => ['status'],
      'payment_status' => ['payment_status'],
      'billing_date' => ['billing_date'],
    ],
  ];

  // ===========================================================================
  // BILLING ITEMS TABLE
  // ===========================================================================
  $schema['billing_items'] = [
    'description' => 'Stores multiple drugs per invoice.',

    'fields' => [

      'id' => [
        'type' => 'serial',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],

      'billing_id' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],

      'drug_id' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],

      'quantity_sold' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 1,
      ],

      'unit_price' => [
        'type' => 'numeric',
        'precision' => 10,
        'scale' => 2,
        'not null' => TRUE,
        'default' => 0,
      ],

      'line_total' => [
        'type' => 'numeric',
        'precision' => 10,
