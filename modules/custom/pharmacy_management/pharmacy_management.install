      'patient_age' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => FALSE,
      ],

      'doctor_name' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => FALSE,
        'default' => '',
